{
  "name": "api-workbench",
  "version": "0.1.0",
  "private": true,
  "description": "Modern Electron-based API testing & workflow platform",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @api-workbench/desktop",
    "build": "npm run build --workspace @api-workbench/desktop",
    "typecheck": "npm run typecheck --workspace @api-workbench/desktop",
    "lint": "npm run lint --workspace @api-workbench/desktop",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,css,md}\"",
    "test": "npm run test --workspace @api-workbench/desktop",
    "test:coverage": "npm run test:coverage --workspace @api-workbench/desktop",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "prettier": "^3.3.3"
  },
  "engines": {
    "node": ">=20"
  }
}
